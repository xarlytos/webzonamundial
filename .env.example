# Sanity.io Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"
SANITY_API_TOKEN=""

# SMTP (waitlist + notifications)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS=""
SMTP_FROM="noreply@zonamundial.app"

# Noticias ingest pipeline (Fase 2)
# GNews — https://gnews.io/dashboard (free tier: 100 req/day)
GNEWS_API_KEY=""

# Cron protection — generate with `openssl rand -hex 32`
# On Vercel, set the same value in Settings → Environment Variables → CRON_SECRET
CRON_SECRET=""

# Anthropic Claude API — used by the article rewriter
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"
